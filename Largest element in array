class Solution {
public:
    int largest(vector<int> &arr) {
        int maxElement = arr[0];  // assume first element is max
        
        for(int i = 1; i < arr.size(); i++) {
            if(arr[i] > maxElement) {
                maxElement = arr[i];
            }
        }
        
        return maxElement;
    }
};
